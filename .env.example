# Use this file as a template for your environment variables.
# Below are values for development environment.
# Copy this file to .env and modify the values as needed.

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

DATABASE_URL_DEV=jdbc:postgresql://sifpi-app-db:5432/sifpi-dev # this url is for one with docker, you may want to change to localhost if using local db
DEV_USERNAME=sifpi-dev
DEV_PASSWORD=developingsifpi
DEV_DB=sifpi-dev

SPRING_PROFILES_ACTIVE=dev

JWT_SECRET=c3VyZWx5IHRoaXMgaXMgbG9uZyBlbm91Z2ggdGhhbiAzMiBjaGFyYWN0ZXJzIG1hbg== # Use any base64 encoded string (at least 32 character) here, this is just an example

# Storage (S3-compatible, for our project we are using Railway's Object Storage, but you can use any S3-compatible storage)
# If you don't have a bucket, you can create one on Railway or any S3-compatible storage provider, then fill in the values below.
# But dont worry, we configure it to be optional, so you can still run the application without filling these values, just make sure to not use any storage-related features (like uploading files) if you don't fill these values.

STORAGE_ENDPOINT=https://your-bucket-endpoint.railway.app
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET_NAME=your-bucket-name
STORAGE_REGION=us-east-1

# Email SendGrid Configuration
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@mhibrizif.site
EMAIL_FROM_NAME=SIFPI
APP_LOGIN_URL=http://localhost:3000/login
